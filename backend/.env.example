# Catalog Health AI — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is gitignored.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                # development | staging | production
LOG_LEVEL=INFO

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_SUPABASE_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── CORS (comma-separated) ────────────────────────────────────────────────────
# Add your Vercel frontend URL here after deploy
CORS_ORIGINS=http://localhost:3000,https://YOUR_APP.vercel.app

# ── Governance rules tuning ───────────────────────────────────────────────────
STALE_ASSET_DAYS=180               # Assets not updated in N days → stale
SCORE_WEIGHT_HIGH=5.0              # Health score penalty per High finding
SCORE_WEIGHT_MEDIUM=3.0            # Penalty per Medium finding
SCORE_WEIGHT_LOW=1.0               # Penalty per Low finding

# ── Email reports (Resend) ────────────────────────────────────────────────────
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_REPLACE_ME
REPORT_RECIPIENT_EMAIL=your-team@company.com
REPORT_SENDER_EMAIL=reports@cataloghealth.ai

# ── Notion integration (for scripts/update_notion_status.py) ─────────────────
# Create integration at: https://www.notion.so/my-integrations
# Then connect it to your Task DB (··· → Connections)
NOTION_TOKEN=secret_REPLACE_ME
NOTION_TASK_DB_ID=23820100f1ac4fc7b1e80e4b92532f69
NOTION_HUB_PAGE_ID=34d8afb1a56f8167a074e9bccadc46d2
